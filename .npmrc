# Hoist all packages to a flat node_modules so React Native
# native build scripts (Gradle, CocoaPods) can resolve paths.
node-linker=hoisted

# But do NOT hoist React itself — the frontend uses React 18
# and the mobile app uses React 19.  Hoisting would let one
# overwrite the other, causing "Invalid hook call" crashes.
# Instead we hoist everything *except* react / react-dom.
public-hoist-pattern[]=*
public-hoist-pattern[]=!react
public-hoist-pattern[]=!react-dom
